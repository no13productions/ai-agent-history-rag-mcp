# Claude History RAG Server - Docker Environment
# Copy to .env and customize as needed

# =============================================================================
# EMBEDDING SERVER (must be running before starting container)
# =============================================================================
# Default: Uses host machine's Ollama via host.docker.internal
# For Mac/Windows, the default works automatically
# For Linux, host.docker.internal is mapped via extra_hosts

# Ollama on host (required)
CLAUDE_HISTORY_RAG_EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
CLAUDE_HISTORY_RAG_EMBEDDING_MODEL=bge-m3

# Alternative: Remote Ollama server
# CLAUDE_HISTORY_RAG_EMBEDDING_BASE_URL=http://192.168.1.100:11434/v1

# Alternative: OpenAI
# CLAUDE_HISTORY_RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
# CLAUDE_HISTORY_RAG_EMBEDDING_MODEL=text-embedding-3-small
# CLAUDE_HISTORY_RAG_EMBEDDING_API_KEY=sk-...

# Alternative: vLLM
# CLAUDE_HISTORY_RAG_EMBEDDING_BASE_URL=http://host.docker.internal:8000/v1

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================
# Port to expose (default: 4680)
# CLAUDE_HISTORY_RAG_PORT=4680

# =============================================================================
# OPTIONAL: Auth (PSK)
# =============================================================================
# Require PSK authentication for dashboard + API endpoints
# CLAUDE_HISTORY_RAG_AUTH_ENABLED=true
# Server PSK override (disables rotation UI)
# CLAUDE_HISTORY_RAG_SERVER_PSK=change-me

# =============================================================================
# OPTIONAL: Performance Tuning
# =============================================================================
# Batch size for embedding (higher = faster but more memory)
# CLAUDE_HISTORY_RAG_BATCH_SIZE=32

# Log level: DEBUG, INFO, WARNING, ERROR
# CLAUDE_HISTORY_RAG_LOG_LEVEL=INFO
